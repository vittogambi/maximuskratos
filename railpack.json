{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "build": {
      "commands": [
        "npm install",
        "npm run db:generate",
        "npm run build -w @mk/database",
        "npm run build -w @mk/api"
      ]
    }
  },
  "deploy": {
    "startCommand": "npm run start:api"
  }
}
